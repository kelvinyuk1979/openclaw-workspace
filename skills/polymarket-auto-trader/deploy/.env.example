# .env - Polymarket Auto-Trader Configuration
# Copy this file to .env and fill in your values
# NEVER commit this file to git!

# Your Polygon wallet private key (without 0x prefix)
# Get this from MetaMask or create a new wallet
PRIVATE_KEY=your-polygon-wallet-private-key-here

# Anthropic API key for LLM probability evaluation
# Get from https://console.anthropic.com/
LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Email for alerts (not implemented yet)
# ALERT_EMAIL=your@email.com
